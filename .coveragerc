[run]
# Modules that fundamentally require a GPU / network / external models / a live
# OCR server / a pre-existing benchmark run are excluded from the Session 7
# coverage gate (they cannot run in the offline, CPU-only test path).
omit =
    */paddle_ocr_provider.py
    */qwen_vl_provider.py
    */qwen_vl_server.py
    */qwen_llama_server.py
    */print_ocr_server.py
    */benchmark_pipeline.py
    */migrate_auto_to_pipeline.py
    */check_providers.py

[report]
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
