# Copy this to .env and fill in your key.
# Get one at https://build.nvidia.com — open any model card, click "Get API Key".
NVIDIA_API_KEY=nvapi-your-key-here

# Only needed if you're pointing at a self-hosted NIM container instead of
# NVIDIA's hosted endpoint:
# NIM_BASE_URL=http://localhost:8000/v1

# Local Ollama LLM Settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=biomistral
OLLAMA_FALLBACK_MODEL=llama3.2:3b
OLLAMA_KEEP_ALIVE=0

# Chandra OCR Settings
CHANDRA_MODEL_ID=datalab-to/chandra-ocr-2
CHANDRA_MAX_MEGAPIXELS=1.0
